# Chirp build-time secrets
# Copy this to .env and fill in real values before building.
# .env is gitignored — never commit real keys.

# Google OAuth credentials for the Sign in with Google flow
# Register a "Desktop app" OAuth client at https://console.cloud.google.com
#   → APIs & Services → Credentials → Create OAuth client ID → Desktop app
# Enable: Cloud API Management API + Generative Language API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Aptabase telemetry (get key at https://aptabase.com)
APTABASE_KEY=

# Sentry crash reporting DSN (get from https://sentry.io project settings)
SENTRY_DSN=

# Discord webhook URL for user feedback (create in Discord channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=
